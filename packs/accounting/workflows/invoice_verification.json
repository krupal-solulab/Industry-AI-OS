{
  "$schema": "aios.workflow/v1",
  "key": "invoice_verification",
  "pack": "accounting",
  "version": "2.0.0",
  "business_goal": "Process an inbound vendor invoice from email end to end: extract it, validate (vendor, duplicate, tax), summarize, get human approval, then EITHER create a bill in the accounting system (QuickBooks/Xero) if connected, OR (demo mode) save the invoice metadata to Google Sheets — then archive the PDF to Drive and email the vendor.",
  "personas": { "primary": "ap_clerk", "supporting": ["accountant", "controller"] },
  "trigger": { "type": "email", "source": "nango.google-mail" },
  "inputs": [
    { "key": "invoice_email", "type": "email", "required": true, "description": "Inbound vendor invoice email (with PDF attachment)" },
    { "key": "has_accounting_connector", "type": "boolean", "required": false, "description": "True if an accounting system (QuickBooks/Xero) is connected for this tenant; false = demo mode (save to Google Sheets)" },
    { "key": "sheet_id", "type": "string", "required": false, "description": "Google Sheet id used as the demo-mode ledger" }
  ],
  "connectors_required": ["nango.google-mail", "nango.google-sheet", "nango.google-drive", "nango.quickbooks"],
  "steps": [
    {
      "id": "read_email",
      "type": "connector.call",
      "name": "Read the invoice email + download the PDF attachment",
      "config": { "connector": "nango.google-mail", "tool": "GET", "arguments": { "endpoint": "/messages/{{ inputs.invoice_email.id }}" } }
    },
    {
      "id": "extract_invoice",
      "type": "document.parse",
      "name": "Eagle Doc — OCR + extraction to structured invoice JSON",
      "config": { "files": "{{ steps.read_email.out.attachments }}", "note": "Digital PDFs via Docling; scanned need the OCR add-on (sandbox extraction until Eagle Doc is wired)." }
    },
    {
      "id": "read_ledger",
      "type": "connector.call",
      "name": "Read existing invoices (duplicate-check source in demo mode)",
      "config": { "connector": "nango.google-sheet", "tool": "GET", "arguments": { "endpoint": "/v4/spreadsheets/{{ inputs.sheet_id }}/values/Invoices" } }
    },
    {
      "id": "validate",
      "type": "ai.action",
      "name": "Accounting AI Validation Engine (vendor, duplicate, tax)",
      "config": {
        "prompt": "invoice_validate",
        "output": "json",
        "context": {
          "invoice": "{{ steps.extract_invoice.out }}",
          "existing_records": "{{ steps.read_ledger.out }}"
        }
      }
    },
    {
      "id": "summary",
      "type": "ai.action",
      "name": "AI validation summary + approve/reject recommendation",
      "config": {
        "prompt": "invoice_summary",
        "output": "json",
        "context": { "invoice": "{{ steps.extract_invoice.out }}", "validation": "{{ steps.validate.out }}" }
      }
    },
    {
      "id": "approval",
      "type": "approval",
      "name": "Human approval (AP)",
      "config": { "summary": "{{ steps.summary.out.text }}", "approver_persona": "controller" }
    },
    {
      "id": "route",
      "type": "branch",
      "name": "Is an accounting connector available?",
      "config": {
        "condition": "{{ inputs.has_accounting_connector }}",
        "on_true": { "use_quickbooks": true, "use_sheets": false },
        "on_false": { "use_quickbooks": false, "use_sheets": true }
      }
    },
    {
      "id": "create_bill",
      "type": "connector.call",
      "name": "Create the bill (QuickBooks/Xero) — when accounting connector is available",
      "when": "{{ steps.route.out.use_quickbooks }}",
      "config": {
        "connector": "nango.quickbooks",
        "tool": "POST",
        "arguments": {
          "endpoint": "/bill",
          "body": {
            "doc_number": "{{ steps.extract_invoice.out.invoice_number }}",
            "total_amount": "{{ steps.extract_invoice.out.total }}",
            "line_items": "{{ steps.extract_invoice.out.line_items }}"
          }
        }
      }
    },
    {
      "id": "save_to_sheets",
      "type": "connector.call",
      "name": "Save invoice metadata to Google Sheets — demo mode (no accounting connector)",
      "when": "{{ steps.route.out.use_sheets }}",
      "config": {
        "connector": "nango.google-sheet",
        "tool": "POST",
        "arguments": {
          "endpoint": "/v4/spreadsheets/{{ inputs.sheet_id }}/values/Invoices:append",
          "body": {
            "values": [[
              "{{ steps.extract_invoice.out.invoice_number }}",
              "{{ steps.extract_invoice.out.vendor_name }}",
              "{{ steps.extract_invoice.out.total }}",
              "{{ steps.summary.out.recommendation }}",
              "approved"
            ]]
          }
        }
      }
    },
    {
      "id": "archive",
      "type": "connector.call",
      "name": "Archive the invoice PDF to Google Drive",
      "config": {
        "connector": "nango.google-drive",
        "tool": "POST",
        "arguments": { "endpoint": "/upload/drive/v3/files", "body": { "name": "invoice-{{ steps.extract_invoice.out.invoice_number }}.pdf" } }
      }
    },
    {
      "id": "notify_vendor",
      "type": "notify",
      "name": "Send approval notification email (Gmail)",
      "config": {
        "connector": "nango.google-mail",
        "tool": "POST",
        "arguments": {
          "endpoint": "/messages/send",
          "body": {
            "to": "{{ steps.read_email.out.from }}",
            "subject": "Invoice {{ steps.extract_invoice.out.invoice_number }} received & approved",
            "body": "{{ steps.summary.out.text }}"
          }
        }
      }
    }
  ],
  "approvals": [{ "step": "approval", "approver_persona": "controller" }],
  "outputs": [
    { "key": "validation", "type": "json", "from": "{{ steps.validate.out }}" },
    { "key": "summary", "type": "string", "from": "{{ steps.summary.out.text }}" }
  ],
  "business_value": "Turns manual AP invoice entry into a 1-2 min human approval over an AI-validated draft. Works with QuickBooks/Xero when connected, or fully in demo mode (Google Sheets) when not — same workflow, one branch."
}
