# =============================================================================
# Industry AI OS — environment template
# -----------------------------------------------------------------------------
# Copy to `.env` for local dev:  cp .env.example .env
# In real environments, secrets are pulled from Infisical/Vault — NOT this file.
# `docker-compose up` must come up green even with all *_API_KEY values blank.
# =============================================================================

# ---- Deployment mode ---------------------------------------------------------
# on-prem | cloud | saas  — influences default isolation & secret backend
DEPLOY_MODE=on-prem
ENVIRONMENT=development
LOG_LEVEL=info

# ---- PostgreSQL (app data + pgvector; also backs keycloak/temporal/langfuse) -
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=aios
POSTGRES_PASSWORD=change-me-in-real-envs
POSTGRES_DB=aios
# App connection string (async driver). Row-Level Security is enforced per tenant.
DATABASE_URL=postgresql+asyncpg://aios:change-me-in-real-envs@postgres:5432/aios
# Sync URL for Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg://aios:change-me-in-real-envs@postgres:5432/aios

# ---- Keycloak (identity / SSO — single realm + Organizations = tenants) ------
# Internal URL (reachable from inside Docker/K8s) — used to fetch JWKS certs.
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=industry-ai-os
KEYCLOAK_CLIENT_ID=aios-gateway
# Dev client secret matches deploy/keycloak/realm-export.json; real envs override.
KEYCLOAK_CLIENT_SECRET=aios-dev-secret
# Admin creds used by the identity service to sync users/roles/orgs
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# PUBLIC issuer string used to validate the token `iss` claim. Must equal Keycloak's
# KC_HOSTNAME-derived issuer. In dev, Keycloak is published on host port 8081.
KEYCLOAK_ISSUER=http://localhost:8081/realms/industry-ai-os

# ---- Cerbos (authorization PDP) ----------------------------------------------
CERBOS_URL=http://cerbos:3592
CERBOS_GRPC=cerbos:3593

# ---- MinIO (S3-compatible object storage) ------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=aios
MINIO_SECRET_KEY=change-me-in-real-envs
MINIO_SECURE=false
MINIO_BUCKET=aios-documents

# ---- Redis / Valkey (cache, sessions, rate-limit buckets) --------------------
REDIS_URL=redis://redis:6379/0

# ---- NATS (eventing / queue) -------------------------------------------------
NATS_URL=nats://nats:4222

# ---- Temporal (durable workflows) --------------------------------------------
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=aios-workflows

# ---- LiteLLM (LLM gateway/routing) -------------------------------------------
LITELLM_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-aios-master-change-me
# Providers — leave blank to boot without keys (orchestrator degrades gracefully).
# Claude is primary; OpenAI is fallback (see deploy/litellm/config.yaml).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Default models (provider-agnostic aliases resolved by LiteLLM)
DEFAULT_CHAT_MODEL=claude-primary
DEFAULT_EMBED_MODEL=text-embedding-3-small

# ---- Langfuse (LLM observability) --------------------------------------------
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ---- OpenTelemetry (service traces/metrics) ----------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAMESPACE=aios
OTEL_TRACES_EXPORTER=otlp

# ---- Infisical (secrets manager — real envs only) ----------------------------
INFISICAL_URL=http://infisical:8080
INFISICAL_TOKEN=
INFISICAL_PROJECT_ID=

# ---- Resend (transactional email) --------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=no-reply@industry-ai-os.local

# ---- Internal service trust (gateway -> downstream) --------------------------
# HMAC secret the gateway uses to sign the internal tenant-context header.
# Downstream services verify it; they NEVER trust a client-supplied tenant id.
INTERNAL_CONTEXT_SECRET=change-me-internal-shared-secret

# ---- Service URLs (used by gateway to route; docker-compose service names) ---
IDENTITY_URL=http://identity:8000
AUTHZ_URL=http://authz:8000
ORCHESTRATOR_URL=http://orchestrator:8000
KNOWLEDGE_URL=http://knowledge:8000
WORKFLOWS_URL=http://workflows:8000
CONNECTORS_URL=http://connectors:8000
AUDIT_URL=http://audit:8000
ADMIN_URL=http://admin:8000

# ---- Rate limiting (gateway) -------------------------------------------------
RATE_LIMIT_PER_MINUTE=120

# ---- CORS (browser frontends allowed to call the gateway) --------------------
# Comma-separated origins. Includes the Vite/TanStack dev ports for the landing
# page in industry-ai-os/. Add your deployed frontend origin here in real envs.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
